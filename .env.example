# Anexis Server Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development
DEBUG=true

# Server Mode: "saas" (default) or "standalone"
# - saas: Full multi-user with JWT auth, storage quotas
# - standalone: Self-hosted with API key auth, no quotas
SERVER_MODE=standalone

# ===================
# Authentication
# ===================
# JWT Secret (for SaaS mode)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24

# API Key (for standalone mode - leave empty for SaaS)
# ANEXIS_API_KEY=your-secret-api-key

# ===================
# Storage Provider
# ===================
# Storage provider: "local", "b2", or "s3"
# For SaaS: defaults to "b2"
# For standalone: defaults to "local"
STORAGE_PROVIDER=local

# Local Storage (used when STORAGE_PROVIDER=local)
STORAGE_LOCAL_PATH=./data/storage

# Backblaze B2 (used when STORAGE_PROVIDER=b2)
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=

# S3-Compatible Storage (used when STORAGE_PROVIDER=s3)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
S3_BASE_PATH=

# ===================
# Database Configuration
# ===================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=anexis
DB_SSLMODE=disable

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ===================
# File Upload Limits
# ===================
MAX_UPLOAD_SIZE_MB=100